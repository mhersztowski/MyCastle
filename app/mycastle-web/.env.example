# Dev mode (.env.development) — loaded by `vite dev`
# Backend runs on port 1896 with separate frontend on 1895
VITE_MQTT_URL=ws://localhost:1896/mqtt
VITE_HTTP_URL=http://localhost:1896

# Production mode (.env.production) — loaded by `vite build`
# Leave empty — URLs are auto-detected from window.location (works behind nginx proxy)
