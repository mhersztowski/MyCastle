{
  "name": "@mhersztowski/mycastle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @mhersztowski/core run build",
    "build:core-backend": "pnpm --filter @mhersztowski/core-backend run build",
    "build:web-client": "pnpm --filter @mhersztowski/web-client run build",
    "build:backend": "pnpm --filter mycastle-backend run build",
    "build:web": "pnpm --filter mycastle-web run build",
    "build:scene3d": "pnpm --filter demo-scene-3d run build",
    "dev:backend": "pnpm --filter mycastle-backend run dev",
    "dev:web": "pnpm --filter mycastle-web run dev",
    "dev:scene3d": "pnpm --filter demo-scene-3d run dev",
"test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "clean": "pnpm -r exec rm -rf dist build",
    "typecheck": "pnpm -r run typecheck",
    "gendocs": "typedoc",
    "gendocs:html": "typedoc --html docs-site/html",
    "gendocs:md": "typedoc --out docs-site/markdown",
    "sync:push": "./scripts/sync.sh push",
    "sync:push:force": "./scripts/sync.sh push --force",
    "sync:pull": "./scripts/sync.sh pull",
    "sync:pull:force": "./scripts/sync.sh pull --force",
    "sync:db-push": "./scripts/sync.sh db-push",
    "sync:db-pull": "./scripts/sync.sh db-pull"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "typedoc": "^0.28.4",
    "typedoc-plugin-markdown": "^4.4.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "node-pty"]
  }
}
