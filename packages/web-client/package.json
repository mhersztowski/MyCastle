{
  "name": "@mhersztowski/web-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mhersztowski/core": "workspace:*",
    "@mhersztowski/ui-core": "workspace:*",
    "mqtt": "^5.3.0",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@mui/material": "^5.15.0 || ^6.0.0",
    "@mui/x-tree-view": "^8.0.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "monaco-editor": ">=0.50.0",
    "@xterm/xterm": ">=5.0.0",
    "@xterm/addon-fit": ">=0.8.0"
  },
  "peerDependenciesMeta": {
    "@mui/material": { "optional": true },
    "@mui/x-tree-view": { "optional": true },
    "@emotion/react": { "optional": true },
    "@emotion/styled": { "optional": true },
    "monaco-editor": { "optional": true },
    "@xterm/xterm": { "optional": true },
    "@xterm/addon-fit": { "optional": true }
  },
  "devDependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^6.1.0",
    "@mui/x-tree-view": "^8.0.0",
    "@types/react": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "jsdom": "^28.1.0",
    "monaco-editor": "^0.52.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0"
  }
}
